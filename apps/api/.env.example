# Copy to apps/api/.env for local dev. On Render, set these in the dashboard.

# Neon Postgres connection string. Copy from Neon dashboard > Connection string.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# 32-byte key, hex-encoded (64 hex chars). Used to encrypt secrets at rest
# and (as fallback) to sign session cookies.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Optional dedicated cookie-signing secret; falls back to APP_ENCRYPTION_KEY.
SESSION_SECRET=

# Bootstrap admin user (only used on first boot when the users table is empty)
ADMIN_EMAIL=admin@invoice.local
ADMIN_PASSWORD=

# Comma-separated allowed web origins. Local dev default: http://localhost:5173
CORS_ORIGIN=

# Optional — Render sets these automatically.
PORT=4000
NODE_ENV=development
